<Window x:Class="CASPERAnalysis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CASPER Analysis" Height="600" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Dataset Selection -->
        <GroupBox Header="Dataset" Grid.Row="0" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding DatasetPath}" IsReadOnly="True" Margin="5"/>
                <Button Grid.Column="1" Content="Browse..." Click="BrowseDataset_Click" Margin="5" Padding="10,5"/>
            </Grid>
        </GroupBox>

        <!-- Experiment Config -->
        <GroupBox Header="Experiment Configuration" Grid.Row="1" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding ExperimentJsonPath, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Column="1" Content="Browse..." Click="BrowseExperimentJson_Click" Margin="5" Padding="10,5"/>
            </Grid>
        </GroupBox>

        <!-- Session Selection -->
        <GroupBox Header="Session" Grid.Row="2" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Select Session:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="1" x:Name="SessionComboBox" 
                          ItemsSource="{Binding Sessions}"
                          SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                          DisplayMemberPath="Name"
                          SelectionChanged="SessionComboBox_SelectionChanged"
                          IsEnabled="{Binding HasSessions}"/>
            </Grid>
        </GroupBox>

        <!-- Topics Data -->
        <GroupBox Header="Topics Data" Grid.Row="3" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="200"/>
                </Grid.RowDefinitions>
                <DataGrid Grid.Row="0" x:Name="TopicsDataGrid" 
                         ItemsSource="{Binding Topics}"
                         AutoGenerateColumns="False"
                         IsReadOnly="True"
                         HeadersVisibility="Column"
                         GridLinesVisibility="All"
                         CanUserResizeColumns="True"
                         MinHeight="200">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Topic" Binding="{Binding TopicName}" Width="*"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding TopicType}" Width="200"/>
                        <DataGridTextColumn Header="Available" Binding="{Binding IsAvailable}" Width="80"/>
                        <DataGridTextColumn Header="Message Count" Binding="{Binding MessageCount}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding MessageCount, StringFormat='{}{0:N0}'}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAnalyzed}" Value="False">
                                            <Setter Property="Text" Value="-"/>
                                            <Setter Property="Foreground" Value="Gray"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Actions" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="Analyze" Click="AnalyzeTopic_Click" 
                                                Tag="{Binding TopicName}"
                                                Padding="5,2"
                                                Margin="0,0,5,0"
                                                IsEnabled="{Binding IsAvailable}"/>
                                        <Button Content="Export CSV" Click="ExportTopicCsv_Click" 
                                                Tag="{Binding TopicName}"
                                                Padding="5,2"
                                                IsEnabled="{Binding IsAnalyzed}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- Log -->
        <GroupBox Header="Log" Grid.Row="4" Margin="0,0,0,10">
            <ScrollViewer x:Name="LogScrollViewer"
                         VerticalScrollBarVisibility="Auto" 
                         HorizontalScrollBarVisibility="Disabled"
                         MaxHeight="200"
                         MinHeight="150">
                <TextBox x:Name="LogTextBox" 
                         Text="{Binding Log}" 
                         IsReadOnly="True" 
                         TextWrapping="Wrap" 
                         FontFamily="Consolas" 
                         FontSize="10"
                         AcceptsReturn="True"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="5"/>
            </ScrollViewer>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Run Analysis" Click="RunAnalysis_Click" Margin="5" Padding="10,5"/>
            <Button Content="Export Results" Click="ExportResults_Click" Margin="5" Padding="10,5"/>
        </StackPanel>
    </Grid>
</Window>

